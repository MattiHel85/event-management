{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/events/layout,_N_T_/(app)/events/new/layout,_N_T_/(app)/events/new/page,_N_T_/events/new"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/events/new/__PAGE__",
    "/!KGFwcCk/events/new",
    "/!KGFwcCk/events",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}