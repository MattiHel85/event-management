generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id          String       @id @default(cuid())
  title       String
  description String
  date        DateTime
  location    String
  capacity    Int
  budget      Float?
  currency    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  budgetItems BudgetItem[]
}

model BudgetItem {
  id          String   @id @default(cuid())
  eventId     String
  category    String
  description String
  amount      Float
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
