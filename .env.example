# MongoDB connection string — get a free cluster at https://mongodb.com/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/event-management?retryWrites=true&w=majority

# (Future) Email service API keys, authentication tokens, etc. go here
# RESEND_API_KEY=
# NEXTAUTH_SECRET=
